import numpy as np

# Traffic flow matrix (vehicles per minute)
# Rows: Incoming roads, Columns: Outgoing roads
traffic_matrix = np.array([
    [30, 20],
    [15, 25]
])

print("Original Traffic Matrix:")
print(traffic_matrix)

# Transformation matrix (signal timing effect)
# Example: adjusting flow based on signal optimization
transformation_matrix = np.array([
    [0.8, 0.2],
    [0.3, 0.7]
])

print("\nTransformation Matrix:")
print(transformation_matrix)

# Apply transformation (matrix multiplication)
new_traffic = np.dot(traffic_matrix, transformation_matrix)

print("\nUpdated Traffic Distribution:")
print(new_traffic)

# Row-wise total traffic
print("\nTotal Traffic from Each Road:")
print(new_traffic.sum(axis=1))

# Column-wise total traffic
print("\nTotal Traffic to Each Direction:")
print(new_traffic.sum(axis=0))
